# ============================================================
# Qwen 微调工具箱 环境变量示例
# 复制为 .env 后按需修改： cp .env.example .env
# ============================================================

# 默认下载来源：modelscope（魔搭，国内推荐）或 huggingface
# 也可在交互菜单里临时切换，这里只是默认值
DEFAULT_SOURCE=modelscope

# 选择魔搭来源时，让 LLaMA-Factory 也从魔搭拉取（1=开启）
USE_MODELSCOPE_HUB=1

# HuggingFace 镜像（国内加速）；走官方留空即可
# HF_ENDPOINT=https://hf-mirror.com

# 缓存目录（默认放在项目内，便于整体迁移）
HF_HOME=./.cache/huggingface
MODELSCOPE_CACHE=./.cache/modelscope

# Ollama 服务地址（一般默认即可）
OLLAMA_HOST=127.0.0.1:11434
